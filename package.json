{
  "name": "leakproof-ai",
  "version": "0.1.0",
  "private": true,
  "description": "AI revenue leakage recovery MVP build pack for Codex.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "env:check": "node scripts/env-check.mjs",
    "production:readiness": "node scripts/production-readiness.mjs",
    "production:gate": "pnpm env:check && pnpm test && pnpm typecheck && pnpm lint && pnpm build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run tests/integration/*.integration.test.ts",
    "test:watch": "vitest",
    "test:e2e": "NEXT_PUBLIC_SUPABASE_URL=https://abcdefghijklmnopqrst.supabase.co NEXT_PUBLIC_SUPABASE_ANON_KEY=e2e-local-anon-key NEXT_PUBLIC_APP_URL=http://127.0.0.1:3120 pnpm exec next build --webpack && playwright test",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "latest",
    "lucide-react": "^1.11.0",
    "mammoth": "^1.12.0",
    "next": "latest",
    "pdf-parse": "^2.4.5",
    "react": "latest",
    "react-dom": "latest",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "zod": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "typescript": "latest",
    "vitest": "latest"
  }
}
